rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // v3: each user owns their own garage document
    match /garages/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
    // Legacy: garages/main for migration (read-only for authenticated users)
    match /garages/main {
      allow read: if request.auth != null;
    }
    match /shares/{token} {
      allow read: if true;
      allow create, delete: if request.auth != null;
    }
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
