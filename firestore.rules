rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /garages/main {
      allow read, write: if request.auth != null
        && request.auth.uid in ['9Vae43tnolSpPiQH5HdY8a4X4Qq2'];
    }
    match /shares/{token} {
      allow read: if true;
      allow create, delete: if request.auth != null
        && request.auth.uid in ['9Vae43tnolSpPiQH5HdY8a4X4Qq2'];
    }
    match /config/{doc} {
      allow read, write: if request.auth != null
        && request.auth.uid in ['9Vae43tnolSpPiQH5HdY8a4X4Qq2'];
    }
  }
}
